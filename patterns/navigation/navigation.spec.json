{
  "name": "Navigation",
  "systems": ["jams-2.1", "biz-jams"],
  "description": "앱 내비게이션 패턴 (탑바, 사이드바, 탭바)",
  "variants": {
    "top-bar": {
      "description": "상단 내비게이션 바 (JAMS 2.1 B2C)",
      "structure": ["logo", "nav-links", "actions (search, profile)"],
      "tokens": {
        "height": "56px",
        "bg": "{color.bg.elevated}",
        "shadow": "{shadow.sm}",
        "padding-x": "{spacing.layout.md}"
      }
    },
    "sidebar": {
      "description": "사이드바 내비게이션 (Biz JAMS B2B)",
      "structure": ["logo", "nav-sections*", "user-menu"],
      "tokens": {
        "width": "240px",
        "width-collapsed": "64px",
        "bg": "{color.bg.sidebar}",
        "text": "{color.text.on-sidebar}",
        "icon": "{color.icon.on-sidebar}",
        "item-padding": "{spacing.3} {spacing.4}",
        "item-radius": "{radius.md}",
        "item-active-bg": "rgba(255,255,255,0.1)"
      }
    },
    "tab-bar": {
      "description": "하단 탭바 (JAMS 2.1 모바일)",
      "structure": ["tab-item* (icon + label)"],
      "tokens": {
        "height": "56px",
        "bg": "{color.bg.elevated}",
        "shadow": "{shadow.md}",
        "active-color": "{color.primary}",
        "inactive-color": "{color.icon.secondary}"
      }
    }
  },
  "accessibility": {
    "role": "navigation",
    "aria-label": "내비게이션 영역 구분을 위한 라벨",
    "aria-current": "현재 활성 페이지/탭 표시",
    "keyboard": "Tab, Arrow keys for navigation items"
  }
}
