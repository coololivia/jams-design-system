{
  "name": "Form Layout",
  "systems": ["jams-core", "jams-2.1", "biz-jams"],
  "description": "폼 입력 필드의 레이아웃과 유효성 검사 패턴",
  "structure": {
    "form": {
      "children": ["form-group*", "form-actions"]
    },
    "form-group": {
      "children": ["label", "input/select/textarea", "helper-text | error-message"]
    },
    "form-actions": {
      "children": ["button (submit)", "button (cancel)"]
    }
  },
  "variants": {
    "vertical": "라벨이 입력 필드 위에 위치 (기본, 모바일 친화)",
    "horizontal": "라벨이 입력 필드 왼쪽에 위치 (데스크톱, Biz JAMS 설정 화면)",
    "inline": "입력 필드들이 한 줄에 나란히 (검색 필터 등)"
  },
  "tokens": {
    "form-group-gap": "{spacing.4}",
    "label-margin-bottom": "{spacing.1}",
    "helper-text-margin-top": "{spacing.1}",
    "helper-text-color": "{color.text.secondary}",
    "error-text-color": "{color.danger}",
    "actions-margin-top": "{spacing.6}",
    "actions-gap": "{spacing.3}"
  },
  "validation": {
    "timing": "onBlur for first validation, onChange after first error",
    "display": "에러 메시지는 필드 바로 아래, 아이콘 + 텍스트"
  },
  "accessibility": {
    "aria-describedby": "에러/헬퍼 텍스트를 입력 필드에 연결",
    "aria-invalid": "에러 상태일 때 true",
    "aria-required": "필수 필드 표시"
  }
}
