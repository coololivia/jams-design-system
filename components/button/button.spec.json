{
  "name": "Button",
  "systems": ["jams-core", "jams-2.1", "biz-jams"],
  "props": {
    "variant": { "type": "enum", "values": ["primary", "secondary", "ghost", "danger"], "default": "primary" },
    "size": { "type": "enum", "values": ["sm", "md", "lg"], "default": "md" },
    "disabled": { "type": "boolean", "default": false },
    "loading": { "type": "boolean", "default": false },
    "fullWidth": { "type": "boolean", "default": false },
    "iconLeft": { "type": "ReactNode", "default": null },
    "iconRight": { "type": "ReactNode", "default": null }
  },
  "tokens": {
    "primary": {
      "bg": "{color.primary}",
      "bg-hover": "{color.primary-hover}",
      "bg-active": "{color.primary-active}",
      "text": "{color.text.on-primary}",
      "border-radius": "{radius.md}",
      "padding-x": "{spacing.4}",
      "padding-y": "{spacing.2}"
    },
    "secondary": {
      "bg": "transparent",
      "border": "{color.border.default}",
      "text": "{color.text.default}",
      "border-radius": "{radius.md}",
      "padding-x": "{spacing.4}",
      "padding-y": "{spacing.2}"
    },
    "ghost": {
      "bg": "transparent",
      "text": "{color.primary}",
      "border-radius": "{radius.md}",
      "padding-x": "{spacing.4}",
      "padding-y": "{spacing.2}"
    },
    "danger": {
      "bg": "{color.danger}",
      "bg-hover": "{color.danger-hover}",
      "text": "{color.text.on-danger}",
      "border-radius": "{radius.md}",
      "padding-x": "{spacing.4}",
      "padding-y": "{spacing.2}"
    }
  },
  "sizes": {
    "sm": { "height": "32px", "font-size": "{typography.font-size.sm}", "padding-x": "{spacing.3}" },
    "md": { "height": "40px", "font-size": "{typography.font-size.md}", "padding-x": "{spacing.4}" },
    "lg": { "height": "48px", "font-size": "{typography.font-size.lg}", "padding-x": "{spacing.5}" }
  },
  "states": ["default", "hover", "active", "focus", "disabled", "loading"],
  "accessibility": {
    "role": "button",
    "keyboard": ["Enter", "Space"],
    "aria": {
      "disabled": "aria-disabled when disabled",
      "busy": "aria-busy when loading"
    }
  }
}
