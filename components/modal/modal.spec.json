{
  "name": "Modal",
  "systems": ["jams-core", "jams-2.1", "biz-jams"],
  "props": {
    "open": { "type": "boolean", "default": false },
    "size": { "type": "enum", "values": ["sm", "md", "lg", "fullscreen"], "default": "md" },
    "title": { "type": "string", "default": null },
    "showClose": { "type": "boolean", "default": true },
    "closeOnOverlay": { "type": "boolean", "default": true },
    "closeOnEsc": { "type": "boolean", "default": true }
  },
  "slots": {
    "header": "모달 상단 영역 (title + close 버튼)",
    "body": "모달 본문 콘텐츠",
    "footer": "모달 하단 액션 영역 (버튼 등)"
  },
  "tokens": {
    "container": {
      "bg": "{color.bg.elevated}",
      "border-radius": "{radius.lg}",
      "shadow": "{shadow.xl}",
      "padding": "{spacing.6}"
    },
    "overlay": {
      "bg": "{color.bg.overlay}"
    },
    "header": {
      "font-size": "{typography.font-size.xl}",
      "font-weight": "{typography.font-weight.semibold}",
      "margin-bottom": "{spacing.4}"
    },
    "footer": {
      "margin-top": "{spacing.4}",
      "gap": "{spacing.3}"
    }
  },
  "sizes": {
    "sm": { "width": "400px", "max-height": "60vh" },
    "md": { "width": "560px", "max-height": "75vh" },
    "lg": { "width": "720px", "max-height": "85vh" },
    "fullscreen": { "width": "100vw", "height": "100vh" }
  },
  "states": ["closed", "opening", "open", "closing"],
  "accessibility": {
    "role": "dialog",
    "keyboard": ["Escape to close", "Tab trapping within modal"],
    "aria": {
      "modal": "aria-modal=true",
      "labelledby": "aria-labelledby linked to title"
    }
  }
}
