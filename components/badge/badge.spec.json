{
  "name": "Badge",
  "systems": ["jams-core", "jams-2.1", "biz-jams"],
  "props": {
    "variant": { "type": "enum", "values": ["filled", "outlined", "subtle"], "default": "filled" },
    "color": { "type": "enum", "values": ["primary", "success", "warning", "danger", "info", "neutral"], "default": "primary" },
    "size": { "type": "enum", "values": ["sm", "md"], "default": "md" },
    "dot": { "type": "boolean", "default": false },
    "removable": { "type": "boolean", "default": false }
  },
  "tokens": {
    "filled-primary": {
      "bg": "{color.primary}",
      "text": "{color.text.on-primary}",
      "border-radius": "{radius.full}"
    },
    "filled-danger": {
      "bg": "{color.danger}",
      "text": "{color.text.on-danger}",
      "border-radius": "{radius.full}"
    },
    "subtle-primary": {
      "bg": "{color.blue.50}",
      "text": "{color.primary}",
      "border-radius": "{radius.full}"
    },
    "outlined-primary": {
      "bg": "transparent",
      "border": "{color.primary}",
      "text": "{color.primary}",
      "border-radius": "{radius.full}"
    }
  },
  "sizes": {
    "sm": { "height": "20px", "font-size": "{typography.font-size.xs}", "padding-x": "{spacing.2}" },
    "md": { "height": "24px", "font-size": "{typography.font-size.sm}", "padding-x": "{spacing.3}" }
  },
  "states": ["default", "hover (if removable)"],
  "accessibility": {
    "role": "status",
    "aria": {
      "label": "aria-label for semantic meaning"
    }
  }
}
