{
  "name": "Card",
  "systems": ["jams-core", "jams-2.1", "biz-jams"],
  "props": {
    "variant": { "type": "enum", "values": ["elevated", "outlined", "filled"], "default": "elevated" },
    "clickable": { "type": "boolean", "default": false },
    "padding": { "type": "enum", "values": ["none", "sm", "md", "lg"], "default": "md" }
  },
  "slots": {
    "media": "상단 이미지/비디오 영역",
    "header": "카드 헤더 (타이틀, 서브타이틀)",
    "body": "카드 본문 콘텐츠",
    "footer": "카드 하단 액션 영역"
  },
  "tokens": {
    "elevated": {
      "bg": "{color.bg.elevated}",
      "shadow": "{shadow.md}",
      "border-radius": "{radius.lg}"
    },
    "outlined": {
      "bg": "{color.bg.base}",
      "border": "{color.border.default}",
      "border-radius": "{radius.lg}"
    },
    "filled": {
      "bg": "{color.bg.surface}",
      "border-radius": "{radius.lg}"
    }
  },
  "sizes": {
    "padding-none": "0px",
    "padding-sm": "{spacing.3}",
    "padding-md": "{spacing.4}",
    "padding-lg": "{spacing.6}"
  },
  "states": ["default", "hover", "active", "focus"],
  "accessibility": {
    "role": "article (or button if clickable)",
    "keyboard": ["Enter/Space if clickable"],
    "aria": {
      "label": "aria-label for clickable cards"
    }
  }
}
