{
  "$description": "D-Button 매트릭스 — DTCG 토큰 기준. variant × state × size 전체 조합.",

  "variants": [
    "button.filled.primary",
    "button.filled.brand",
    "button.filled.brand-dim",
    "button.filled.subtle",
    "button.outlined.brand",
    "button.outlined.default",
    "button.outlined.pill",
    "button.borderless.default",
    "button.borderless.pill",
    "button.borderless.subtle"
  ],

  "states": ["default", "D-hover", "disabled", "loading"],

  "sizes": ["lg", "md", "sm", "xs"],

  "sizeSpecs": {
    "lg": { "height": 52, "padding": "14 16", "gap": 6, "borderRadius": 10, "leftIconSize": 20, "rightIconSize": 14, "fontSize": "16px (b2)", "$status": "✅ confirmed" },
    "md": { "height": 48, "padding": "12 14", "gap": 6, "borderRadius": 10, "leftIconSize": 20, "rightIconSize": 14, "fontSize": "16px (b2)", "$status": "✅ confirmed" },
    "sm": { "height": 40, "padding": "10 12", "gap": 4, "borderRadius": 10, "fontSize": "14px (b4)", "$status": "✅ confirmed" },
    "xs": { "height": 32, "padding": "0 10", "gap": 4, "borderRadius": 6, "fontSize": "13px (c1)", "$status": "✅ confirmed" }
  },

  "variantTokens": {
    "button.filled.primary": {
      "bg": "color.bg.interactive",
      "text": "color.icon.inverse",
      "border": "none",
      "$category": "filled",
      "$status": "✅ confirmed"
    },
    "button.filled.brand": {
      "bg": "color.bg.brand",
      "text": "color.icon.inverse",
      "border": "none",
      "$category": "filled",
      "$status": "✅ confirmed"
    },
    "button.filled.brand-dim": {
      "bg": "color.bg.brand-dim",
      "text": "color.icon.inverse",
      "border": "none",
      "$category": "filled",
      "$status": "✅ confirmed"
    },
    "button.filled.subtle": {
      "bg": "color.bg.brand-subtle",
      "text": "color.text.brand",
      "border": "color.border.brand Inside 1px",
      "$category": "filled-subtle",
      "$status": "✅ confirmed"
    },
    "button.outlined.brand": {
      "bg": "color.bg.base",
      "text": "color.text.brand",
      "border": "color.border.brand Inside 1px",
      "$category": "outlined-brand",
      "$status": "✅ confirmed"
    },
    "button.outlined.default": {
      "bg": "color.bg.base",
      "text": "color.text.primary",
      "border": "color.border.default Inside 1px",
      "$category": "outlined",
      "$status": "✅ confirmed"
    },
    "button.outlined.pill": {
      "bg": "color.bg.base",
      "text": "color.text.primary",
      "border": "color.border.default Inside 1px",
      "borderRadiusOverride": 999,
      "$category": "outlined-pill",
      "$status": "✅ confirmed"
    },
    "button.borderless.default": {
      "bg": "color.bg.base",
      "text": "color.text.primary",
      "border": "none",
      "$category": "borderless",
      "$status": "✅ confirmed"
    },
    "button.borderless.pill": {
      "bg": "color.bg.base",
      "text": "color.text.primary",
      "border": "none",
      "borderRadiusOverride": 999,
      "$category": "borderless-pill",
      "$status": "✅ confirmed"
    },
    "button.borderless.subtle": {
      "bg": "color.bg.brand-subtle",
      "text": "color.text.brand",
      "border": "none",
      "$category": "borderless-brand",
      "$status": "✅ confirmed"
    }
  },

  "stateOverrides": {
    "default": { "$status": "✅ — variant 토큰 그대로 적용" },
    "D-hover": {
      "bg": "color.bg.interactive-hover (동일 시맨틱 토큰, Variable Mode가 hover resolve 값으로 자동 변환)",
      "text": "변경 없음",
      "$mechanism": "opacity/overlay 아님. Variable Mode가 hover 상태에서 더 진한 값으로 resolve",
      "$status": "✅ confirmed"
    },
    "disabled": {
      "bg": "color.bg.interactive-disabled",
      "text": "color.text.disabled",
      "$mechanism": "opacity 방식이 아닌 토큰 교체 방식",
      "$status": "✅ confirmed"
    },
    "loading": {
      "bg": "default와 동일 (color.bg.interactive)",
      "text": "숨김",
      "spinner": "system-loading 20x20",
      "$mechanism": "bg 유지, label 숨기고 spinner로 대체, 클릭 불가",
      "$status": "✅ confirmed"
    }
  },

  "progress": {
    "total": "10 variants × 4 states × 4 sizes = 160 조합",
    "confirmed": { "sizeSpecs": "4/4 ✅", "variantTokens": "10/10 ✅", "stateOverrides": "4/4 ✅" }
  }
}
