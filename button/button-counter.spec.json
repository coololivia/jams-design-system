{
  "$description": "카운트 버튼 섹션 — JAMS 2.1. DTCG 토큰 기준.",
  "$figmaSource": "https://www.figma.com/design/Dojrcqpr6br5B6BNkj08jR/JAMS-2.0?m=dev",
  "$figmaSection": "카운트 버튼",
  "$status": "extracted-from-figma",

  "components": {

    "ButtonCounter": {
      "$description": "카운트 버튼 — 텍스트 라벨 + 숫자 배지(99) 조합",
      "props": {
        "size": { "type": "enum", "values": ["40", "32"] },
        "state": { "type": "enum", "values": ["default", "D-hover", "disabled"] },
        "label": { "type": "string", "default": "버튼명" }
      },
      "layout": {
        "flow": "Horizontal",
        "height": "Fixed (40px)",
        "radius": "radius.component.xs",
        "border": "1px Inside",
        "padding": { "left": "unit-12", "right": "unit-12" },
        "gap": "unit-4"
      },
      "tokens": {
        "default": {
          "bg": "color.bg.surface",
          "border": "color.border.default",
          "text": "color.text.secondary",
          "count": "color.text.brand"
        },
        "D-hover": { "$description": "Variable Mode로 bg 토큰이 hover 값으로 resolve" },
        "disabled": { "$description": "bg/text 토큰 교체 방식 (opacity 아님)" }
      },
      "layers": [
        "\"버튼명\" (color.text.secondary)",
        "\"99\" (color.text.brand)"
      ],
      "darkMode": "있음",
      "$status": "✅ confirmed"
    },

    "ButtonPaginationCounterWhite": {
      "$description": "페이지네이션 카운터 화이트 버전 — 어두운 배경 위 흰색 카운터",
      "$status": "✅ 존재 확인"
    }
  },

  "progress": {
    "ButtonCounter": "✅ confirmed",
    "ButtonPaginationCounterWhite": "✅ 존재 확인"
  }
}
