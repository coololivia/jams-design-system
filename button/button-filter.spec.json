{
  "$description": "필터 버튼 섹션 — JAMS 2.1. DTCG 토큰 기준.",
  "$figmaSource": "https://www.figma.com/design/Dojrcqpr6br5B6BNkj08jR/JAMS-2.0?m=dev",
  "$figmaSection": "필터 버튼",
  "$status": "extracted-from-figma",

  "components": {

    "button.filter.icon-text": {
      "$description": "필터 아이콘 버튼 — 아이콘 + 텍스트 + 상태 뱃지(체크/카운트) 조합",
      "props": {
        "state": { "type": "enum", "values": ["off", "on"] },
        "variant": { "type": "enum", "values": ["text", "icon"] },
        "mark": { "type": "enum", "values": ["none", "check", "count"] }
      },
      "layout": {
        "flow": "Horizontal",
        "height": "Fixed (32px)",
        "radius": "100px (pill)",
        "border": "1px Inside",
        "padding": { "left": "unit-8", "right": "unit-10" },
        "gap": "2px"
      },
      "tokens": {
        "state:off": {
          "bg": "color.bg.base",
          "border": "color.border.default",
          "icon": "color.icon.primary",
          "text": "color.text.tertiary"
        },
        "state:on": {
          "bg": "color.bg.interactive",
          "border": "none",
          "icon": "color.icon.inverse",
          "text": "color.icon.inverse"
        }
      },
      "$status": "✅ confirmed"
    },

    "button.filter.item": {
      "$description": "필터 드롭다운 버튼 — 텍스트 + 드롭다운 화살표 조합",
      "props": {
        "state": { "type": "enum", "values": ["off", "on", "disabled"] },
        "variant": { "type": "enum", "values": ["outlined"] }
      },
      "layout": {
        "flow": "Horizontal",
        "height": "Fixed (32px)",
        "radius": "40px",
        "border": "1px Inside",
        "padding": { "left": "unit-12", "right": "unit-10" },
        "gap": "unit-2"
      },
      "tokens": {
        "state:off": {
          "bg": "color.bg.base",
          "border": "color.border.default",
          "text": "color.text.secondary"
        },
        "state:on": {
          "bg": "color.bg.interactive",
          "border": "none",
          "text": "color.icon.inverse"
        },
        "disabled": {
          "bg": "color.bg.base",
          "border": "color.border.subtle",
          "text": "color.text.disabled"
        }
      },
      "$status": "✅ off 상태 confirmed"
    },

    "button.filter.icon-only": {
      "$description": "필터 선택 결과 표시 버튼 — 선택된 필터 값을 pill 형태로 표시",
      "props": {
        "size": { "type": "enum", "values": ["40", "32"] },
        "state": { "type": "enum", "values": ["off", "on"] },
        "label": { "type": "string", "default": "전체" }
      },
      "layout": {
        "flow": "Horizontal",
        "radius": "unit-999 (pill)",
        "border": "1px Inside",
        "gap": "unit-4"
      },
      "tokens": {
        "state:off": {
          "bg": "color.bg.base",
          "border": "color.border.default",
          "text": "color.text.secondary",
          "icon": "color.icon.secondary"
        },
        "state:on": {
          "bg": "color.bg.interactive",
          "border": "none",
          "text": "color.icon.inverse",
          "icon": "color.icon.inverse"
        }
      },
      "$status": "✅ confirmed"
    }
  },

  "progress": {
    "button.filter.icon-text": "✅ confirmed",
    "button.filter.item": "✅ off confirmed",
    "button.filter.icon-only": "✅ confirmed"
  }
}
