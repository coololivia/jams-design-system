{
  "$description": "JAMS 2.1 — JK Brand, Dark Mode brand overrides. Apply after semantic-dark.tokens.json. Neutral dark tokens (bg/text/border/icon non-brand) are in semantic-dark.tokens.json.",

  "color": {
    "bg": {
      "interactive":        { "$value": "{color.blue2.400}", "$type": "color" },
      "interactive-hover":  { "$value": "{color.blue2.300}", "$type": "color" },
      "interactive-active": { "$value": "{color.blue2.200}", "$type": "color" },
      "brand":              { "$value": "{color.blue2.400}", "$type": "color" },
      "brand-dim":          { "$value": "{color.blue2.300}", "$type": "color" },
      "brand-subtle":       { "$value": "{color.blue2.900}", "$type": "color" },
      "brand-subtle-hover": { "$value": "{color.blue2.800}", "$type": "color" }
    },
    "text": {
      "brand": { "$value": "{color.blue2.300}", "$type": "color" }
    },
    "border": {
      "brand":        { "$value": "{color.blue2.400}", "$type": "color" },
      "brand-subtle": { "$value": "{color.blue2.700}", "$type": "color" }
    },
    "icon": {
      "brand": { "$value": "{color.blue2.300}", "$type": "color" }
    }
  }
}
