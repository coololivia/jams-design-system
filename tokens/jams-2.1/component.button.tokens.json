{
  "$description": "JAMS 2.1 — Button component tokens (DTCG). 패턴: button.{군}.{variant}.{size}",

  "button": {

    "filled": {
      "$description": "배경이 채워진 주요 버튼 (Heavy)",
      "primary": {
        "$description": "브랜드 primary fill — JK=blue2.500, AM=orange.500",
        "lg": { "$value": { "bg": "{color.bg.interactive}",       "text": "{color.text.inverse}", "radius": "{radius.component.md}", "height": "{spacing.52}", "paddingH": "{spacing.16}", "fontSize": "16px" }, "$type": "composite" },
        "md": { "$value": { "bg": "{color.bg.interactive}",       "text": "{color.text.inverse}", "radius": "{radius.component.md}", "height": "{spacing.48}", "paddingH": "{spacing.14}", "fontSize": "16px" }, "$type": "composite" },
        "sm": { "$value": { "bg": "{color.bg.interactive}",       "text": "{color.text.inverse}", "radius": "{radius.component.md}", "height": "{spacing.40}", "paddingH": "{spacing.12}", "fontSize": "14px" }, "$type": "composite" },
        "xs": { "$value": { "bg": "{color.bg.interactive}",       "text": "{color.text.inverse}", "radius": "{radius.component.xs}", "height": "{spacing.32}", "paddingH": "{spacing.10}", "fontSize": "13px" }, "$type": "composite" }
      },
      "brand": {
        "$description": "브랜드 500 fill (=primary와 동일하나 별도 variant 존재)",
        "lg": { "$value": { "bg": "{color.bg.brand}",             "text": "{color.text.inverse}", "radius": "{radius.component.md}", "height": "{spacing.52}", "paddingH": "{spacing.16}", "fontSize": "16px" }, "$type": "composite" },
        "md": { "$value": { "bg": "{color.bg.brand}",             "text": "{color.text.inverse}", "radius": "{radius.component.md}", "height": "{spacing.48}", "paddingH": "{spacing.14}", "fontSize": "16px" }, "$type": "composite" },
        "sm": { "$value": { "bg": "{color.bg.brand}",             "text": "{color.text.inverse}", "radius": "{radius.component.md}", "height": "{spacing.40}", "paddingH": "{spacing.12}", "fontSize": "14px" }, "$type": "composite" },
        "xs": { "$value": { "bg": "{color.bg.brand}",             "text": "{color.text.inverse}", "radius": "{radius.component.xs}", "height": "{spacing.32}", "paddingH": "{spacing.10}", "fontSize": "13px" }, "$type": "composite" }
      },
      "brand-dim": {
        "$description": "브랜드 400 (dim) fill",
        "lg": { "$value": { "bg": "{color.bg.brand-dim}",         "text": "{color.text.inverse}", "radius": "{radius.component.md}", "height": "{spacing.52}", "paddingH": "{spacing.16}", "fontSize": "16px" }, "$type": "composite" },
        "md": { "$value": { "bg": "{color.bg.brand-dim}",         "text": "{color.text.inverse}", "radius": "{radius.component.md}", "height": "{spacing.48}", "paddingH": "{spacing.14}", "fontSize": "16px" }, "$type": "composite" },
        "sm": { "$value": { "bg": "{color.bg.brand-dim}",         "text": "{color.text.inverse}", "radius": "{radius.component.md}", "height": "{spacing.40}", "paddingH": "{spacing.12}", "fontSize": "14px" }, "$type": "composite" },
        "xs": { "$value": { "bg": "{color.bg.brand-dim}",         "text": "{color.text.inverse}", "radius": "{radius.component.xs}", "height": "{spacing.32}", "paddingH": "{spacing.10}", "fontSize": "13px" }, "$type": "composite" }
      },
      "subtle": {
        "$description": "브랜드 50 (subtle) fill + 브랜드 텍스트 + 브랜드 테두리",
        "lg": { "$value": { "bg": "{color.bg.brand-subtle}",      "text": "{color.text.brand}", "border": "{color.border.brand-subtle}", "radius": "{radius.component.md}", "height": "{spacing.52}", "paddingH": "{spacing.16}", "fontSize": "16px" }, "$type": "composite" },
        "md": { "$value": { "bg": "{color.bg.brand-subtle}",      "text": "{color.text.brand}", "border": "{color.border.brand-subtle}", "radius": "{radius.component.md}", "height": "{spacing.48}", "paddingH": "{spacing.14}", "fontSize": "16px" }, "$type": "composite" },
        "sm": { "$value": { "bg": "{color.bg.brand-subtle}",      "text": "{color.text.brand}", "border": "{color.border.brand-subtle}", "radius": "{radius.component.md}", "height": "{spacing.40}", "paddingH": "{spacing.12}", "fontSize": "14px" }, "$type": "composite" },
        "xs": { "$value": { "bg": "{color.bg.brand-subtle}",      "text": "{color.text.brand}", "border": "{color.border.brand-subtle}", "radius": "{radius.component.xs}", "height": "{spacing.32}", "paddingH": "{spacing.10}", "fontSize": "13px" }, "$type": "composite" }
      }
    },

    "outlined": {
      "$description": "테두리 있는 보조 버튼 (Heavy)",
      "brand": {
        "$description": "outlined bg + 브랜드 텍스트 + default 테두리",
        "lg": { "$value": { "bg": "{color.bg.interactive-disabled}", "text": "{color.text.brand}",    "border": "{color.border.default}", "radius": "{radius.component.md}", "height": "{spacing.52}", "paddingH": "{spacing.16}", "fontSize": "16px" }, "$type": "composite" },
        "md": { "$value": { "bg": "{color.bg.interactive-disabled}", "text": "{color.text.brand}",    "border": "{color.border.default}", "radius": "{radius.component.md}", "height": "{spacing.48}", "paddingH": "{spacing.14}", "fontSize": "16px" }, "$type": "composite" },
        "sm": { "$value": { "bg": "{color.bg.interactive-disabled}", "text": "{color.text.brand}",    "border": "{color.border.default}", "radius": "{radius.component.md}", "height": "{spacing.40}", "paddingH": "{spacing.12}", "fontSize": "14px" }, "$type": "composite" },
        "xs": { "$value": { "bg": "{color.bg.interactive-disabled}", "text": "{color.text.brand}",    "border": "{color.border.default}", "radius": "{radius.component.xs}", "height": "{spacing.32}", "paddingH": "{spacing.10}", "fontSize": "13px" }, "$type": "composite" }
      },
      "default": {
        "$description": "outlined bg + 기본 텍스트 + default 테두리",
        "lg": { "$value": { "bg": "{color.bg.interactive-disabled}", "text": "{color.text.primary}",  "border": "{color.border.default}", "radius": "{radius.component.md}", "height": "{spacing.52}", "paddingH": "{spacing.16}", "fontSize": "16px" }, "$type": "composite" },
        "md": { "$value": { "bg": "{color.bg.interactive-disabled}", "text": "{color.text.primary}",  "border": "{color.border.default}", "radius": "{radius.component.md}", "height": "{spacing.48}", "paddingH": "{spacing.14}", "fontSize": "16px" }, "$type": "composite" },
        "sm": { "$value": { "bg": "{color.bg.interactive-disabled}", "text": "{color.text.primary}",  "border": "{color.border.default}", "radius": "{radius.component.md}", "height": "{spacing.40}", "paddingH": "{spacing.12}", "fontSize": "14px" }, "$type": "composite" },
        "xs": { "$value": { "bg": "{color.bg.interactive-disabled}", "text": "{color.text.primary}",  "border": "{color.border.default}", "radius": "{radius.component.xs}", "height": "{spacing.32}", "paddingH": "{spacing.10}", "fontSize": "13px" }, "$type": "composite" }
      },
      "pill": {
        "$description": "outlined + radius pill (999)",
        "lg": { "$value": { "bg": "{color.bg.interactive-disabled}", "text": "{color.text.primary}",  "border": "{color.border.default}", "radius": "{radius.component.pill}", "height": "{spacing.52}", "paddingH": "{spacing.16}", "fontSize": "16px" }, "$type": "composite" },
        "md": { "$value": { "bg": "{color.bg.interactive-disabled}", "text": "{color.text.primary}",  "border": "{color.border.default}", "radius": "{radius.component.pill}", "height": "{spacing.48}", "paddingH": "{spacing.14}", "fontSize": "16px" }, "$type": "composite" },
        "sm": { "$value": { "bg": "{color.bg.interactive-disabled}", "text": "{color.text.primary}",  "border": "{color.border.default}", "radius": "{radius.component.pill}", "height": "{spacing.40}", "paddingH": "{spacing.12}", "fontSize": "14px" }, "$type": "composite" },
        "xs": { "$value": { "bg": "{color.bg.interactive-disabled}", "text": "{color.text.primary}",  "border": "{color.border.default}", "radius": "{radius.component.pill}", "height": "{spacing.32}", "paddingH": "{spacing.10}", "fontSize": "13px" }, "$type": "composite" }
      }
    },

    "borderless": {
      "$description": "배경·테두리 없는 Tertiary 버튼 (Light)",
      "default": {
        "lg": { "$value": { "bg": "transparent", "text": "{color.text.primary}",  "radius": "{radius.component.md}", "height": "{spacing.52}", "paddingH": "{spacing.16}", "fontSize": "16px" }, "$type": "composite" },
        "md": { "$value": { "bg": "transparent", "text": "{color.text.primary}",  "radius": "{radius.component.md}", "height": "{spacing.48}", "paddingH": "{spacing.14}", "fontSize": "16px" }, "$type": "composite" },
        "sm": { "$value": { "bg": "transparent", "text": "{color.text.primary}",  "radius": "{radius.component.md}", "height": "{spacing.40}", "paddingH": "{spacing.12}", "fontSize": "14px" }, "$type": "composite" },
        "xs": { "$value": { "bg": "transparent", "text": "{color.text.primary}",  "radius": "{radius.component.xs}", "height": "{spacing.32}", "paddingH": "{spacing.10}", "fontSize": "13px" }, "$type": "composite" }
      },
      "pill": {
        "lg": { "$value": { "bg": "transparent", "text": "{color.text.primary}",  "radius": "{radius.component.pill}", "height": "{spacing.52}", "paddingH": "{spacing.16}", "fontSize": "16px" }, "$type": "composite" },
        "md": { "$value": { "bg": "transparent", "text": "{color.text.primary}",  "radius": "{radius.component.pill}", "height": "{spacing.48}", "paddingH": "{spacing.14}", "fontSize": "16px" }, "$type": "composite" },
        "sm": { "$value": { "bg": "transparent", "text": "{color.text.primary}",  "radius": "{radius.component.pill}", "height": "{spacing.40}", "paddingH": "{spacing.12}", "fontSize": "14px" }, "$type": "composite" },
        "xs": { "$value": { "bg": "transparent", "text": "{color.text.primary}",  "radius": "{radius.component.pill}", "height": "{spacing.32}", "paddingH": "{spacing.10}", "fontSize": "13px" }, "$type": "composite" }
      },
      "subtle": {
        "$description": "borderless + brand-subtle bg + 브랜드 텍스트",
        "lg": { "$value": { "bg": "{color.bg.brand-subtle}", "text": "{color.text.brand}", "radius": "{radius.component.md}", "height": "{spacing.52}", "paddingH": "{spacing.16}", "fontSize": "16px" }, "$type": "composite" },
        "md": { "$value": { "bg": "{color.bg.brand-subtle}", "text": "{color.text.brand}", "radius": "{radius.component.md}", "height": "{spacing.48}", "paddingH": "{spacing.14}", "fontSize": "16px" }, "$type": "composite" },
        "sm": { "$value": { "bg": "{color.bg.brand-subtle}", "text": "{color.text.brand}", "radius": "{radius.component.md}", "height": "{spacing.40}", "paddingH": "{spacing.12}", "fontSize": "14px" }, "$type": "composite" },
        "xs": { "$value": { "bg": "{color.bg.brand-subtle}", "text": "{color.text.brand}", "radius": "{radius.component.xs}", "height": "{spacing.32}", "paddingH": "{spacing.10}", "fontSize": "13px" }, "$type": "composite" }
      }
    },

    "icon": {
      "$description": "정사각형 아이콘 전용 버튼 (W=H). 3 states: default/hover/disabled. Loading 없음.",
      "primary":    {
        "lg": { "$value": { "bg": "{color.bg.interactive}", "icon": "{color.icon.inverse}", "radius": "{radius.component.pill}", "size": "{spacing.52}" }, "$type": "composite" },
        "md": { "$value": { "bg": "{color.bg.interactive}", "icon": "{color.icon.inverse}", "radius": "{radius.component.pill}", "size": "{spacing.48}" }, "$type": "composite" },
        "sm": { "$value": { "bg": "{color.bg.interactive}", "icon": "{color.icon.inverse}", "radius": "{radius.component.pill}", "size": "{spacing.40}" }, "$type": "composite" },
        "xs": { "$value": { "bg": "{color.bg.interactive}", "icon": "{color.icon.inverse}", "radius": "{radius.component.pill}", "size": "{spacing.32}" }, "$type": "composite" }
      },
      "brand": {
        "$description": "brand-dim (400) fill, pill",
        "lg": { "$value": { "bg": "{color.bg.brand-dim}",  "icon": "{color.icon.inverse}", "radius": "{radius.component.pill}", "size": "{spacing.52}" }, "$type": "composite" },
        "md": { "$value": { "bg": "{color.bg.brand-dim}",  "icon": "{color.icon.inverse}", "radius": "{radius.component.pill}", "size": "{spacing.48}" }, "$type": "composite" },
        "sm": { "$value": { "bg": "{color.bg.brand-dim}",  "icon": "{color.icon.inverse}", "radius": "{radius.component.pill}", "size": "{spacing.40}" }, "$type": "composite" },
        "xs": { "$value": { "bg": "{color.bg.brand-dim}",  "icon": "{color.icon.inverse}", "radius": "{radius.component.pill}", "size": "{spacing.32}" }, "$type": "composite" }
      },
      "outlined": {
        "$description": "surface bg + default 테두리, rounded rect",
        "lg": { "$value": { "bg": "{color.bg.interactive-disabled}", "icon": "{color.icon.primary}", "border": "{color.border.default}", "radius": "{radius.component.md}", "size": "{spacing.52}" }, "$type": "composite" },
        "md": { "$value": { "bg": "{color.bg.interactive-disabled}", "icon": "{color.icon.primary}", "border": "{color.border.default}", "radius": "{radius.component.md}", "size": "{spacing.48}" }, "$type": "composite" },
        "sm": { "$value": { "bg": "{color.bg.interactive-disabled}", "icon": "{color.icon.primary}", "border": "{color.border.default}", "radius": "{radius.component.md}", "size": "{spacing.40}" }, "$type": "composite" },
        "xs": { "$value": { "bg": "{color.bg.interactive-disabled}", "icon": "{color.icon.primary}", "border": "{color.border.default}", "radius": "{radius.component.xs}", "size": "{spacing.32}" }, "$type": "composite" }
      },
      "circle": {
        "$description": "surface bg + default 테두리, pill",
        "lg": { "$value": { "bg": "{color.bg.interactive-disabled}", "icon": "{color.icon.primary}", "border": "{color.border.default}", "radius": "{radius.component.pill}", "size": "{spacing.52}" }, "$type": "composite" },
        "md": { "$value": { "bg": "{color.bg.interactive-disabled}", "icon": "{color.icon.primary}", "border": "{color.border.default}", "radius": "{radius.component.pill}", "size": "{spacing.48}" }, "$type": "composite" },
        "sm": { "$value": { "bg": "{color.bg.interactive-disabled}", "icon": "{color.icon.primary}", "border": "{color.border.default}", "radius": "{radius.component.pill}", "size": "{spacing.40}" }, "$type": "composite" },
        "xs": { "$value": { "bg": "{color.bg.interactive-disabled}", "icon": "{color.icon.primary}", "border": "{color.border.default}", "radius": "{radius.component.pill}", "size": "{spacing.32}" }, "$type": "composite" }
      },
      "borderless": {
        "$description": "bg/border 없음, pill",
        "lg": { "$value": { "bg": "transparent", "icon": "{color.icon.primary}", "radius": "{radius.component.pill}", "size": "{spacing.52}" }, "$type": "composite" },
        "md": { "$value": { "bg": "transparent", "icon": "{color.icon.primary}", "radius": "{radius.component.pill}", "size": "{spacing.48}" }, "$type": "composite" },
        "sm": { "$value": { "bg": "transparent", "icon": "{color.icon.primary}", "radius": "{radius.component.pill}", "size": "{spacing.40}" }, "$type": "composite" },
        "xs": { "$value": { "bg": "transparent", "icon": "{color.icon.primary}", "radius": "{radius.component.pill}", "size": "{spacing.32}" }, "$type": "composite" }
      },
      "dark": {
        "$description": "gray95060 — 어두운 bg, 흰 아이콘",
        "lg": { "$value": { "bg": "{color.bg.dark}", "icon": "{color.icon.inverse}", "radius": "{radius.6}", "size": "{spacing.52}" }, "$type": "composite" },
        "md": { "$value": { "bg": "{color.bg.dark}", "icon": "{color.icon.inverse}", "radius": "{radius.6}", "size": "{spacing.48}" }, "$type": "composite" },
        "sm": { "$value": { "bg": "{color.bg.dark}", "icon": "{color.icon.inverse}", "radius": "{radius.6}", "size": "{spacing.40}" }, "$type": "composite" },
        "xs": { "$value": { "bg": "{color.bg.dark}", "icon": "{color.icon.inverse}", "radius": "{radius.6}", "size": "{spacing.32}" }, "$type": "composite" }
      }
    },

    "text": {
      "$description": "bg·border·padding 없는 텍스트 버튼 (ButtonText + ButtonIcontext)",
      "brand": {
        "lg": { "$value": { "text": "{color.text.brand}", "fontSize": "16px" }, "$type": "composite" },
        "md": { "$value": { "text": "{color.text.brand}", "fontSize": "14px" }, "$type": "composite" },
        "sm": { "$value": { "text": "{color.text.brand}", "fontSize": "13px" }, "$type": "composite" }
      },
      "primary": {
        "lg": { "$value": { "text": "{color.text.primary}", "fontSize": "16px" }, "$type": "composite" },
        "md": { "$value": { "text": "{color.text.primary}", "fontSize": "14px" }, "$type": "composite" },
        "sm": { "$value": { "text": "{color.text.primary}", "fontSize": "13px" }, "$type": "composite" }
      },
      "secondary": {
        "sm": { "$value": { "text": "{color.text.secondary}", "fontSize": "13px" }, "$type": "composite" }
      },
      "link": {
        "$description": "ButtonIcontext — 텍스트 + 화살표 아이콘",
        "md": { "$value": { "text": "{color.text.secondary}", "icon": "{color.icon.secondary}", "fontSize": "13px" }, "$type": "composite" },
        "sm": { "$value": { "text": "{color.text.brand}",    "icon": "{color.icon.brand}",     "fontSize": "12px" }, "$type": "composite" }
      }
    },

    "filter": {
      "$description": "h=32px 고정 pill. off/on Variable Mode 전환.",
      "item":      { "$value": { "height": "{spacing.32}", "radius": "{radius.component.pill}", "bg-off": "{color.bg.interactive-disabled}", "text-off": "{color.text.tertiary}", "border-off": "{color.border.default}", "bg-on": "{color.bg.interactive}", "text-on": "{color.text.inverse}" }, "$type": "composite" },
      "icon-text": { "$value": { "height": "{spacing.32}", "radius": "{radius.component.pill}", "bg-off": "{color.bg.interactive-disabled}", "text-off": "{color.text.tertiary}", "border-off": "{color.border.default}", "bg-on": "{color.bg.interactive}", "text-on": "{color.text.inverse}" }, "$type": "composite" },
      "icon-only": { "$value": { "height": "{spacing.32}", "radius": "{radius.component.pill}", "bg-off": "{color.bg.interactive-disabled}", "icon-off": "{color.icon.secondary}", "border-off": "{color.border.default}", "bg-on": "{color.bg.interactive}", "icon-on": "{color.icon.inverse}" }, "$type": "composite" }
    },

    "floating": { "$value": { "bg": "{color.bg.dark}", "text": "{color.text.inverse}", "radius": "{radius.component.pill}", "height": "{spacing.40}", "paddingH": "{spacing.16}", "fontSize": "14px" }, "$type": "composite" },

    "search": {
      "lg": { "$value": { "bg": "{color.bg.interactive}", "text": "{color.text.inverse}", "radius": "{radius.component.pill}", "height": "{spacing.40}", "paddingH": "{spacing.14}", "fontSize": "14px" }, "$type": "composite" },
      "sm": { "$value": { "bg": "{color.bg.interactive}", "text": "{color.text.inverse}", "radius": "{radius.component.pill}", "height": "{spacing.32}", "paddingH": "{spacing.12}", "fontSize": "13px" }, "$type": "composite" }
    },

    "top": { "$value": { "bg": "{color.bg.base}", "icon": "{color.icon.primary}", "border": "{color.border.default}", "radius": "{radius.component.pill}", "size": "{spacing.56}" }, "$type": "composite" }
  }
}
