{
  "$description": "JAMS 2.1 — JK Brand (Blue2 #1B55F6), Light Mode. semantic.tokens.json의 brand 계열 override. Dark mode brand: theme-jk-dark.tokens.json",

  "color": {
    "bg": {
      "interactive":        { "$value": "{color.blue2.500}", "$type": "color" },
      "interactive-hover":  { "$value": "{color.blue2.600}", "$type": "color" },
      "interactive-active": { "$value": "{color.blue2.700}", "$type": "color" },
      "brand":              { "$value": "{color.blue2.500}", "$type": "color" },
      "brand-dim":          { "$value": "{color.blue2.400}", "$type": "color" },
      "brand-subtle":       { "$value": "{color.blue2.50}",  "$type": "color" },
      "brand-subtle-hover": { "$value": "{color.blue2.100}", "$type": "color" }
    },
    "text": {
      "brand": { "$value": "{color.blue2.500}", "$type": "color" }
    },
    "border": {
      "brand":        { "$value": "{color.blue2.500}", "$type": "color" },
      "brand-subtle": { "$value": "{color.blue2.200}", "$type": "color" },
      "focus":        { "$value": "{color.blue2.500}", "$type": "color" }
    },
    "icon": {
      "brand": { "$value": "{color.blue2.500}", "$type": "color" }
    }
  },
  "radius": {
    "component": {
      "md": { "$value": "{radius.10}", "$type": "dimension", "$description": "JK 버튼 lg/md/sm radius" },
      "xs": { "$value": "{radius.6}",  "$type": "dimension", "$description": "JK 버튼 xs radius" }
    }
  }
}
