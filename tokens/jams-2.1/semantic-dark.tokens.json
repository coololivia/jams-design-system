{
  "$description": "JAMS 2.1 — Dark Mode neutral overrides. Apply on top of semantic.tokens.json. Brand dark overrides are in theme-{brand}-dark.tokens.json.",

  "color": {
    "bg": {
      "base":                 { "$value": "{color.gray.950}", "$type": "color", "$description": "다크 기본 배경" },
      "surface":              { "$value": "{color.gray.900}", "$type": "color", "$description": "다크 surface" },
      "elevated":             { "$value": "{color.gray.800}", "$type": "color", "$description": "다크 모달·토스트" },
      "interactive-disabled": { "$value": "{color.gray.800}", "$type": "color", "$description": "다크 disabled bg" },
      "interactive-secondary-hovered": { "$value": "{color.gray.800}", "$type": "color", "$description": "다크 secondary 버튼 hover bg+border" }
    },
    "text": {
      "primary":   { "$value": "{color.gray.50}",  "$type": "color" },
      "secondary": { "$value": "{color.gray.300}", "$type": "color" },
      "tertiary":  { "$value": "{color.gray.500}", "$type": "color" },
      "disabled":  { "$value": "{color.gray.700}", "$type": "color" }
    },
    "border": {
      "default": { "$value": "{color.gray.700}", "$type": "color" },
      "subtle":  { "$value": "{color.gray.800}", "$type": "color" },
      "strong":  { "$value": "{color.gray.600}", "$type": "color" }
    },
    "icon": {
      "primary":   { "$value": "{color.gray.300}", "$type": "color" },
      "secondary": { "$value": "{color.gray.500}", "$type": "color" }
    }
  }
}
