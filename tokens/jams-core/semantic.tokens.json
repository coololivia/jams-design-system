{
  "$description": "JAMS Core — 레거시 호환 시맨틱 토큰. JAMS 2.1이 canonical이며, Core는 기존 프로덕트 호환을 위해 유지됩니다.",
  "$status": "legacy",
  "color": {
    "primary":        { "$value": "{color.jk.500}",   "$type": "color", "$description": "Core는 JK 브랜드 컬러를 기본으로 사용" },
    "primary-hover":  { "$value": "{color.jk.600}",   "$type": "color" },
    "secondary":      { "$value": "{color.gray.500}", "$type": "color" },
    "danger":         { "$value": "{color.red.500}",  "$type": "color" },
    "warning":        { "$value": "{color.yellow.500}", "$type": "color" },
    "success":        { "$value": "{color.green.500}", "$type": "color" },
    "bg": {
      "base":     { "$value": "{color.white}",     "$type": "color" },
      "surface":  { "$value": "{color.gray.50}",   "$type": "color" },
      "elevated": { "$value": "{color.white}",     "$type": "color" },
      "overlay":  { "$value": "rgba(0,0,0,0.5)",   "$type": "color" }
    },
    "text": {
      "default":     { "$value": "{color.gray.800}", "$type": "color", "$deprecated": "2.1에서는 near-black(#1A1A1E) 사용" },
      "secondary":   { "$value": "{color.gray.500}", "$type": "color", "$deprecated": "2.1에서는 gray.600 사용" },
      "disabled":    { "$value": "{color.gray.300}", "$type": "color" },
      "on-primary":  { "$value": "{color.white}",    "$type": "color" },
      "link":        { "$value": "{color.blue.500}",  "$type": "color" }
    },
    "border": {
      "default": { "$value": "{color.gray.200}", "$type": "color" },
      "focus":   { "$value": "{color.blue.500}", "$type": "color" }
    }
  },
  "spacing": {
    "$description": "Core는 sm/md/lg alias를 사용. 2.1은 숫자 기반(spacing.2, spacing.4)으로 전환됨.",
    "xs": { "$value": "{spacing.1}", "$type": "dimension", "$deprecated": "2.1에서는 spacing.1 직접 참조" },
    "sm": { "$value": "{spacing.2}", "$type": "dimension", "$deprecated": "2.1에서는 spacing.2 직접 참조" },
    "md": { "$value": "{spacing.4}", "$type": "dimension", "$deprecated": "2.1에서는 spacing.4 직접 참조" },
    "lg": { "$value": "{spacing.6}", "$type": "dimension", "$deprecated": "2.1에서는 spacing.6 직접 참조" },
    "xl": { "$value": "{spacing.8}", "$type": "dimension", "$deprecated": "2.1에서는 spacing.8 직접 참조" }
  }
}
