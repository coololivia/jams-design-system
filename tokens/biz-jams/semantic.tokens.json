{
  "$description": "Biz JAMS (B2B) — Semantic tokens for business applications",
  "color": {
    "primary":        { "$value": "{color.blue.600}",  "$type": "color" },
    "primary-hover":  { "$value": "{color.blue.700}",  "$type": "color" },
    "primary-active": { "$value": "{color.blue.800}",  "$type": "color" },
    "secondary":      { "$value": "{color.gray.600}",  "$type": "color" },
    "secondary-hover": { "$value": "{color.gray.700}", "$type": "color" },
    "danger":         { "$value": "{color.red.600}",   "$type": "color" },
    "danger-hover":   { "$value": "{color.red.700}",   "$type": "color" },
    "warning":        { "$value": "{color.yellow.500}", "$type": "color" },
    "success":        { "$value": "{color.green.600}",  "$type": "color" },
    "info":           { "$value": "{color.blue.500}",   "$type": "color" },
    "bg": {
      "base":     { "$value": "{color.white}",      "$type": "color" },
      "surface":  { "$value": "{color.gray.50}",    "$type": "color" },
      "elevated": { "$value": "{color.white}",      "$type": "color" },
      "overlay":  { "$value": "rgba(0,0,0,0.5)",    "$type": "color" },
      "disabled": { "$value": "{color.gray.100}",   "$type": "color" },
      "sidebar":  { "$value": "{color.gray.950}",   "$type": "color" }
    },
    "text": {
      "default":     { "$value": "{color.near-black}",  "$type": "color" },
      "secondary":   { "$value": "{color.gray.600}",    "$type": "color" },
      "tertiary":    { "$value": "{color.gray.400}",    "$type": "color" },
      "disabled":    { "$value": "{color.gray.300}",    "$type": "color" },
      "on-primary":  { "$value": "{color.white}",       "$type": "color" },
      "on-danger":   { "$value": "{color.white}",       "$type": "color" },
      "on-sidebar":  { "$value": "{color.gray.100}",    "$type": "color" },
      "link":        { "$value": "{color.blue.600}",    "$type": "color" },
      "link-hover":  { "$value": "{color.blue.700}",    "$type": "color" }
    },
    "border": {
      "default": { "$value": "{color.gray.200}", "$type": "color" },
      "strong":  { "$value": "{color.gray.400}", "$type": "color" },
      "focus":   { "$value": "{color.blue.500}", "$type": "color" },
      "error":   { "$value": "{color.red.500}",  "$type": "color" }
    },
    "icon": {
      "default":    { "$value": "{color.gray.600}", "$type": "color" },
      "secondary":  { "$value": "{color.gray.400}", "$type": "color" },
      "on-primary": { "$value": "{color.white}",    "$type": "color" },
      "on-sidebar": { "$value": "{color.gray.300}", "$type": "color" }
    },
    "data": {
      "$description": "Colors for data visualization in B2B dashboards",
      "chart-1": { "$value": "{color.blue.500}",   "$type": "color" },
      "chart-2": { "$value": "{color.green.500}",  "$type": "color" },
      "chart-3": { "$value": "{color.am.500}",     "$type": "color" },
      "chart-4": { "$value": "{color.violet.500}", "$type": "color" },
      "chart-5": { "$value": "{color.red.500}",    "$type": "color" }
    }
  },
  "spacing": {
    "component": {
      "xs": { "$value": "{spacing.1}", "$type": "dimension" },
      "sm": { "$value": "{spacing.2}", "$type": "dimension" },
      "md": { "$value": "{spacing.3}", "$type": "dimension" },
      "lg": { "$value": "{spacing.4}", "$type": "dimension" },
      "xl": { "$value": "{spacing.6}", "$type": "dimension" }
    },
    "layout": {
      "xs": { "$value": "{spacing.4}",  "$type": "dimension" },
      "sm": { "$value": "{spacing.6}",  "$type": "dimension" },
      "md": { "$value": "{spacing.8}",  "$type": "dimension" },
      "lg": { "$value": "{spacing.12}", "$type": "dimension" },
      "xl": { "$value": "{spacing.16}", "$type": "dimension" }
    }
  }
}
