{
  "$description": "BizJAMS — Light Mode. color.bg.interactive 계열만 Biz 브랜드(blue.600)로 override.",
  "color": {
    "bg": {
      "interactive":         { "$value": "{color.blue.600}",  "$type": "color" },
      "interactive-hover":   { "$value": "{color.blue.700}",  "$type": "color" },
      "interactive-active":  { "$value": "{color.blue.800}",  "$type": "color" },
      "brand":               { "$value": "{color.blue.600}",  "$type": "color" },
      "brand-dim":           { "$value": "{color.blue.500}",  "$type": "color" },
      "brand-subtle":        { "$value": "{color.blue.50}",   "$type": "color" },
      "brand-subtle-hover":  { "$value": "{color.blue.100}",  "$type": "color" },
      "sidebar":             { "$value": "{color.gray.950}",  "$type": "color" },
      "sidebar-active":      { "$value": "{color.gray.800}",  "$type": "color" }
    },
    "text": {
      "brand": { "$value": "{color.blue.600}", "$type": "color" }
    },
    "border": {
      "brand":        { "$value": "{color.blue.600}", "$type": "color" },
      "brand-subtle": { "$value": "{color.blue.200}", "$type": "color" },
      "focus":        { "$value": "{color.blue.600}", "$type": "color" }
    },
    "icon": {
      "brand": { "$value": "{color.blue.600}", "$type": "color" }
    }
  }
}
